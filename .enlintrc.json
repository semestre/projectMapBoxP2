{
    "parserOptions": {
        "ecmaVersion": 2018
    },
    "extends": ["eslint:resommended", "prettier"],
    "env": {
        "es6": true,
        "node": true,
        "jest": true
    },
    " rules": {
        "no-console": "warn",
        "no-unused-vars": "warn",
        "semi": ["error", "always"],
        "quotes": ["error", "single"]
    }
}